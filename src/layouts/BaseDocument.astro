---
import { ClientRouter } from 'astro:transitions';
import { Font } from 'astro:assets';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  siteName: string;
  bodyClass: string;
  ogType?: 'website' | 'article';
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
}

const {
  title,
  description,
  siteName,
  bodyClass,
  ogType = 'website',
  ogTitle = title,
  ogDescription = description,
  ogImage
} = Astro.props;

const resolvedOgImage = ogImage && ogImage.length > 0 ? ogImage : null;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    {resolvedOgImage && <meta property="og:image" content={resolvedOgImage} />}
    <Font
      cssVariable="--font-cormorant-garamond"
      preload={[{ weight: 300, style: 'normal', subset: 'latin' }]}
    />
    <Font
      cssVariable="--font-space-mono"
      preload={[{ weight: 400, style: 'normal', subset: 'latin' }]}
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <ClientRouter />
    <slot name="head" />
  </head>
  <body class:list={[bodyClass, 'antialiased']}>
    <slot />
  </body>
</html>
