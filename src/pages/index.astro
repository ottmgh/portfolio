---
import BaseDocument from '../layouts/BaseDocument.astro';
import { getHomepageBranches, getPortfolioContent } from '../lib/portfolio';

const { site, home, projects, categories } = await getPortfolioContent();
const branches = getHomepageBranches(projects, categories);
const ogImage = home.ogImage || site.ogImage;
const hasIntroVideo = Boolean(home.introVideo);

type GraphNode = {
  id: string;
  type: 'root' | 'category' | 'project' | 'link';
  label: string;
  href?: string;
  parentId?: string;
  childCount?: number;
};

type GraphLink = {
  source: string;
  target: string;
  type: 'primary' | 'child';
};

const graphNodes: GraphNode[] = [{ id: 'root', type: 'root', label: home.artistName }];
const graphLinks: GraphLink[] = [];

for (const branch of branches) {
  if (branch.type === 'category') {
    graphNodes.push({
      id: branch.id,
      type: 'category',
      label: branch.label,
      childCount: branch.children.length
    });
    graphLinks.push({ source: 'root', target: branch.id, type: 'primary' });

    for (const child of branch.children) {
      graphNodes.push({
        id: child.id,
        type: 'project',
        label: child.label,
        href: child.href,
        parentId: branch.id
      });
      graphLinks.push({
        source: branch.id,
        target: child.id,
        type: 'child'
      });
    }
  } else {
    graphNodes.push({ id: branch.id, type: 'link', label: branch.label, href: branch.href });
    graphLinks.push({ source: 'root', target: branch.id, type: 'primary' });
  }
}

const graphData = JSON.stringify({ nodes: graphNodes, links: graphLinks }).replace(
  /</g,
  '\\u003c'
);
---

<BaseDocument
  title={site.siteTitle}
  description={site.siteDescription}
  siteName={site.siteTitle}
  bodyClass="home-page"
  ogImage={ogImage}
>
  <script slot="head" is:inline>
    try {
      if (sessionStorage.getItem('portfolio:intro-seen') === 'true') {
        document.documentElement.classList.add('intro-seen');
      }
    } catch {}
  </script>

  <noscript slot="head">
    <style>
      #video-intro { display: none !important; }
      #tree-view { opacity: 1 !important; pointer-events: all !important; }
    </style>
  </noscript>

  {hasIntroVideo && (
    <div id="video-intro">
      <video id="intro-video" muted playsinline autoplay>
        <source src={home.introVideo} type="video/mp4" />
      </video>
      <button id="skip-btn">{home.skipLabel}</button>
    </div>
  )}

  <div id="tree-view">
    <div id="tree-container">
      <div class="tree-atmosphere" aria-hidden="true">
        {Array.from({ length: 24 }).map((_, index) => (
          <span
            class="particle"
            style={`left:${(index * 17) % 100}%; animation-duration:${9 + (index % 5) * 3}s; animation-delay:${(index % 7) * 0.8}s; width:${1 + (index % 3)}px; height:${1 + (index % 3)}px;`}
          ></span>
        ))}
      </div>
      <div class="root-node" id="root">
        <div class="root-pulse"></div>
        <h1>{home.artistName}</h1>
        <span class="subtitle">{home.artistSubtitle}</span>
      </div>

      <svg class="home-graph" aria-label="Homepage navigation graph" role="navigation">
        <g class="graph-links" aria-hidden="true"></g>
        <g class="graph-nodes"></g>
      </svg>
      <script id="home-graph-data" type="application/json" set:html={graphData} is:inline></script>

      <nav class="home-graph-fallback" aria-label="Homepage navigation">
        {branches.map((branch) => (
          <section>
            {branch.type === 'category' ? (
              <>
                <h2>{branch.label}</h2>
                <ul>
                  {branch.children.map((child) => (
                    <li>
                      <a href={child.href}>{child.label}</a>
                    </li>
                  ))}
                </ul>
              </>
            ) : (
              <a href={branch.href}>{branch.label}</a>
            )}
          </section>
        ))}
      </nav>
    </div>

  </div>

  <div id="page-transition"></div>

  <script src="../scripts/home.ts"></script>
</BaseDocument>
