---
import BaseDocument from '../layouts/BaseDocument.astro';
import { getPortfolioContent } from '../lib/portfolio';

const { about, site } = await getPortfolioContent();
const pageTitle = `About | ${site.siteTitle}`;
const ogImage = site.ogImage;
const AboutBody = about.Body;
---

<BaseDocument
  title={pageTitle}
  description={about.summary}
  siteName={site.siteTitle}
  ogTitle="About"
  stylesheet="/styles/project.css"
  bodyClass="detail-page detail-page--about"
  ogImage={ogImage}
>
  <a href="/" class="back-link">
    <span class="back-arrow"></span>
    back
  </a>

  <main class="page-shell page-shell--about">
    <header class="page-header">
      <p class="eyebrow">Archive</p>
      <h1 class="page-title">About</h1>
      <p class="page-intro">{about.summary}</p>
    </header>

    <section class="page-body page-body--single">
      <div class="text-block">
        <AboutBody />
      </div>
    </section>
  </main>
</BaseDocument>
