---
import BaseDocument from '../layouts/BaseDocument.astro';
import { fade } from 'astro:transitions';
import { getPortfolioContent } from '../lib/portfolio';

const { about, site } = await getPortfolioContent();
const pageTitle = `About | ${site.siteTitle}`;
const ogImage = site.ogImage;
const AboutBody = about.Body;
---

<BaseDocument
  title={pageTitle}
  description={about.summary}
  siteName={site.siteTitle}
  ogTitle="About"
  bodyClass="detail-page detail-page--about"
  ogImage={ogImage}
  ogImageAlt={`${site.siteTitle} about preview`}
>
  <a
    href="/"
    transition:name="back-nav"
    class="back-link fixed top-7 left-7 z-10 inline-flex items-center gap-2 font-mono text-[0.6rem] tracking-[0.34em] uppercase text-white/35 no-underline transition-colors duration-500 hover:text-white/80"
  >
    <svg
      class="back-arrow"
      width="22"
      height="8"
      viewBox="0 0 22 8"
      fill="none"
      stroke="currentColor"
      stroke-width="1"
      stroke-linecap="square"
      aria-hidden="true"
    >
      <line x1="0.5" y1="4" x2="22" y2="4" />
      <polyline points="4,0.5 0.5,4 4,7.5" />
    </svg>
    back
  </a>

  <main transition:animate={fade({ duration: '0.4s' })} class="mx-auto flex min-h-screen max-w-2xl flex-col justify-center px-5 py-24 md:px-8 md:py-28">
    <header class="mb-12 md:mb-16">
      <h1 class="mb-4 text-4xl font-light tracking-[0.22em] md:text-6xl">About</h1>
      <p class="text-lg leading-relaxed text-balance text-white/70 md:text-2xl md:leading-relaxed">{about.summary}</p>
    </header>

    <section>
      <div class="text-lg leading-relaxed text-white/60 space-y-6">
        <AboutBody />
      </div>
    </section>
  </main>
</BaseDocument>
