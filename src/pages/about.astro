---
import BaseDocument from '../layouts/BaseDocument.astro';
import { getPortfolioContent } from '../lib/portfolio';

const { about, home } = await getPortfolioContent();
const pageTitle = `${about.title} | ${home.siteTitle}`;
---

<BaseDocument
  title={pageTitle}
  description={about.intro}
  siteName={home.siteTitle}
  ogTitle={about.title}
  stylesheet="/styles/project.css"
  bodyClass="detail-page detail-page--about"
>
  <a href="/" class="back-link">
    <span class="back-arrow"></span>
    back
  </a>

  <main class="page-shell page-shell--about">
    <header class="page-header">
      <p class="eyebrow">Archive</p>
      <h1 class="page-title">{about.title}</h1>
      <p class="page-intro">{about.intro}</p>
    </header>

    <section class="page-body page-body--single">
      <div class="text-block">
        <p class="body-copy">{about.body}</p>
      </div>
    </section>
  </main>
</BaseDocument>
