---
import BaseDocument from '../../layouts/BaseDocument.astro';
import { fade } from 'astro:transitions';
import { getPortfolioContent } from '../../lib/portfolio';

export async function getStaticPaths() {
  const { site, projects } = await getPortfolioContent();

  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { site, project }
  }));
}

const { site, project } = Astro.props;
const pageTitle = `${project.title} | ${site.siteTitle}`;
const ogImage = project.ogImage || site.ogImage;
const ProjectBody = project.Body;
---

<BaseDocument
  title={pageTitle}
  description={project.summary}
  siteName={site.siteTitle}
  ogType="article"
  ogTitle={project.title}
  bodyClass="detail-page detail-page--project"
  ogImage={ogImage}
>
  <a
    href="/"
    transition:name="back-nav"
    class="back-link fixed top-7 left-7 z-10 inline-flex items-center gap-2 font-mono text-[0.6rem] tracking-[0.34em] uppercase text-white/35 no-underline transition-colors duration-500 hover:text-white/80"
  >
    <svg
      class="back-arrow"
      width="22"
      height="8"
      viewBox="0 0 22 8"
      fill="none"
      stroke="currentColor"
      stroke-width="1"
      stroke-linecap="square"
      aria-hidden="true"
    >
      <line x1="0.5" y1="4" x2="22" y2="4" />
      <polyline points="4,0.5 0.5,4 4,7.5" />
    </svg>
    back
  </a>

  <main transition:animate={fade({ duration: '0.4s' })} class="mx-auto max-w-5xl px-5 pt-28 pb-16 md:px-8 md:pt-36 md:pb-24">
    <header class="mb-12 max-w-2xl md:mb-16">
      <p class="mb-4 font-mono text-[0.6rem] tracking-[0.34em] uppercase text-white/40 md:mb-5">{project.category.label} · {project.year}</p>
      <h1 class="text-4xl font-light tracking-[0.22em] md:text-6xl">{project.title}</h1>
    </header>

    {project.video && (
      <section class="mb-14 md:mb-16">
        <div class="relative">
          <video controls playsinline preload="metadata" class="block w-full">
            <source src={project.video} type="video/mp4" />
          </video>
          <div class="pointer-events-none absolute -inset-px border border-white/[0.07]"></div>
        </div>
      </section>
    )}

    <section class="max-w-2xl">
      <p class="mb-6 text-xl font-light leading-relaxed text-balance text-white/70 md:mb-8 md:text-2xl md:leading-relaxed">{project.summary}</p>
      <div class="text-lg leading-relaxed text-white/60 space-y-6">
        <ProjectBody />
      </div>
    </section>
  </main>

  <script>
    document.addEventListener('astro:page-load', () => {
      document.querySelectorAll<HTMLVideoElement>('video[controls]').forEach((v) => v.load());
    });
  </script>
</BaseDocument>
