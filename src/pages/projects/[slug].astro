---
import BaseDocument from '../../layouts/BaseDocument.astro';
import { getPortfolioContent } from '../../lib/portfolio';

export async function getStaticPaths() {
  const { home, projects } = await getPortfolioContent();

  return projects.map((project) => ({
    params: { slug: project.data.slug },
    props: { home, project }
  }));
}

const { home, project } = Astro.props;
const pageTitle = `${project.data.title} | ${home.siteTitle}`;
---

<BaseDocument
  title={pageTitle}
  description={project.data.description}
  siteName={home.siteTitle}
  ogType="article"
  ogTitle={project.data.title}
  stylesheet="/styles/project.css"
  bodyClass="detail-page detail-page--project"
>
  <a href="/" class="back-link">
    <span class="back-arrow"></span>
    back
  </a>

  <main class="page-shell">
    <header class="page-header">
      <p class="eyebrow">{project.data.category}</p>
      <h1 class="page-title">{project.data.title}</h1>
      <p class="page-meta">{project.data.category} · {project.data.year}</p>
    </header>

    {project.data.video && (
      <section class="video-section">
        <div class="video-wrapper">
          <video controls playsinline preload="metadata">
            <source src={project.data.video} type="video/mp4" />
          </video>
          <div class="video-border"></div>
        </div>
      </section>
    )}

    <section class="page-body">
      <div class="text-block">
        <p class="body-copy">{project.data.description}</p>
      </div>

      <dl class="meta-list">
        <div>
          <dt>Category</dt>
          <dd>{project.data.category}</dd>
        </div>
        <div>
          <dt>Year</dt>
          <dd>{project.data.year}</dd>
        </div>
      </dl>
    </section>
  </main>
</BaseDocument>
