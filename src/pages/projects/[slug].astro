---
import BaseDocument from '../../layouts/BaseDocument.astro';
import { fade } from 'astro:transitions';
import { getPortfolioContent } from '../../lib/portfolio';

export async function getStaticPaths() {
  const { site, projects } = await getPortfolioContent();

  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { site, project }
  }));
}

const { site, project } = Astro.props;
const pageTitle = `${project.title} | ${site.siteTitle}`;
const ogImage = project.ogImage || site.ogImage;
const ProjectBody = project.Body;
---

<BaseDocument
  title={pageTitle}
  description={project.summary}
  siteName={site.siteTitle}
  ogType="article"
  ogTitle={project.title}
  bodyClass="detail-page detail-page--project"
  ogImage={ogImage}
  ogImageAlt={`${project.title} by ${site.siteTitle}`}
>
  <a
    href="/"
    transition:name="back-nav"
    class="back-link fixed top-7 left-7 z-10 inline-flex items-center gap-2 font-mono text-[0.6rem] tracking-[0.34em] uppercase text-white/35 no-underline transition-colors duration-500 hover:text-white/80"
  >
    <svg
      class="back-arrow"
      width="22"
      height="8"
      viewBox="0 0 22 8"
      fill="none"
      stroke="currentColor"
      stroke-width="1"
      stroke-linecap="square"
      aria-hidden="true"
    >
      <line x1="0.5" y1="4" x2="22" y2="4" />
      <polyline points="4,0.5 0.5,4 4,7.5" />
    </svg>
    back
  </a>

  <main transition:animate={fade({ duration: '0.4s' })} class="mx-auto max-w-5xl px-5 pt-20 pb-16 md:px-8 md:pt-7 md:pb-24">
    <header class="mb-12 max-w-2xl md:mb-16">
      <p class="mb-4 font-mono text-[0.6rem] tracking-[0.24em] uppercase text-white/40 md:mb-5 md:tracking-[0.34em]">{project.category.label} · {project.year}</p>
      <h1 class="text-3xl font-light tracking-[0.12em] md:text-6xl md:tracking-[0.22em]">{project.title}</h1>
    </header>

    {project.videoEmbed && (
      <section class="mb-14 md:mb-16">
        <div class="relative aspect-video overflow-hidden bg-black">
          <iframe
            src={project.videoEmbed.src}
            title={`${project.title} ${project.videoEmbed.title}`}
            class="absolute inset-0 block h-full w-full"
            loading="lazy"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; fullscreen; gyroscope; picture-in-picture; web-share"
            allowfullscreen
          ></iframe>
          <div class="pointer-events-none absolute -inset-px border border-white/[0.07]"></div>
        </div>
      </section>
    )}

    <section class="max-w-2xl">
      <p class="mb-6 text-xl font-medium leading-[1.72] text-balance text-white/90 md:mb-8 md:text-2xl md:leading-[1.72]">{project.summary}</p>
      <div class="editorial-prose text-xl font-medium leading-[1.72] tracking-[0.015em] text-white/85 space-y-6 md:text-2xl md:leading-[1.72]">
        <ProjectBody />
      </div>
    </section>
  </main>

</BaseDocument>
